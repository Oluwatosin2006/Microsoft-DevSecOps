        <mxCell id="1GCHogoU7hfo9mal9Wpi-1" parent="1" style="text;whiteSpace=wrap;html=1;fontSize=18;" value="An organization approached our consulting team to improve their existing CI/CD pipeline processes and consolidate their tooling into a single platform. They decided to adopt Microsoft Azure DevOps to centralize source control, build and release pipelines, and project management workflows.&lt;br&gt;&lt;br&gt;After gathering and analyzing their requirements, we conducted face-to-face workshops with key stakeholders to align on architecture, governance, security, and migration strategy. We then:&lt;br&gt;&lt;br&gt;&lt;ul&gt;&lt;li&gt;Designed and established the Azure DevOps organization structure&lt;/li&gt;&lt;li&gt;Defined project segmentation aligned to business units and application domains&lt;/li&gt;&lt;li&gt;Configured repositories, branching strategies, and access controls&lt;/li&gt;&lt;li&gt;Implemented standardized CI/CD pipelines and reusable templates&lt;/li&gt;&lt;li&gt;Integrated security scanning and DevSecOps practices&lt;/li&gt;&lt;li&gt;Supported multiple teams during onboarding and migration&lt;/li&gt;&lt;li&gt;Provided training, documentation, and best practices guidance&lt;/li&gt;&lt;/ul&gt;&lt;br&gt;This enabled the client to streamline delivery processes, improve visibility across teams, strengthen governance, and accelerate deployment cycles within a unified DevOps platform&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="410" width="1050.4" x="228.42000000000002" y="831" as="geometry" />
        </mxCell>
        <mxCell id="1GCHogoU7hfo9mal9Wpi-9" parent="1" style="text;whiteSpace=wrap;html=1;fontSize=18;" value="&lt;font&gt;In Microsoft Azure DevOps, the hierarchy is structured as follows&lt;/font&gt;&lt;div&gt;&lt;font&gt;&lt;br&gt;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font&gt;Organization&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font&gt;:&lt;/font&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="40" width="570" x="243.25000000000003" y="1320" as="geometry" />
        </mxCell>
        <mxCell id="1GCHogoU7hfo9mal9Wpi-12" parent="1" style="whiteSpace=wrap;html=1;aspect=fixed;fillColor=#dae8fc;strokeColor=#6c8ebf;gradientColor=#7ea6e0;" value="" vertex="1">
          <mxGeometry height="29.18" width="29.18" x="240.82" y="1480" as="geometry" />
        </mxCell>
        <mxCell id="1GCHogoU7hfo9mal9Wpi-13" parent="1" style="text;whiteSpace=wrap;html=1;" value="&lt;font style=&quot;font-size: 18px;&quot;&gt;Repos | Pipelines | Boards | Artifacts | Test Plans&lt;/font&gt;" vertex="1">
          <mxGeometry height="40" width="395.1" x="234.9" y="1530" as="geometry" />
        </mxCell>
        <mxCell id="1GCHogoU7hfo9mal9Wpi-14" parent="1" style="text;whiteSpace=wrap;html=1;" value="&lt;font style=&quot;font-size: 18px;&quot;&gt;Projects&lt;/font&gt;" vertex="1">
          <mxGeometry height="40" width="80" x="250.2" y="1440" as="geometry" />
        </mxCell>
        <mxCell id="1GCHogoU7hfo9mal9Wpi-16" parent="1" style="whiteSpace=wrap;html=1;aspect=fixed;fillColor=#dae8fc;strokeColor=#6c8ebf;gradientColor=#7ea6e0;" value="" vertex="1">
          <mxGeometry height="29.18" width="29.18" x="240.61" y="1400" as="geometry" />
        </mxCell>
        <mxCell id="1GCHogoU7hfo9mal9Wpi-17" parent="1" style="text;whiteSpace=wrap;html=1;" value="&lt;font style=&quot;font-size: 18px;&quot;&gt;Explanation:&lt;br&gt;&lt;br&gt;&lt;/font&gt;&lt;ul&gt;&lt;li&gt;&lt;font style=&quot;font-size: 18px;&quot;&gt;Organization&lt;/font&gt;&lt;/li&gt;&lt;/ul&gt;&lt;font style=&quot;font-size: 18px;&quot;&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp;The top-level container that manages users, security, billing, and overall governance.&lt;br&gt;&lt;br&gt;&lt;/font&gt;&lt;ul&gt;&lt;li&gt;&lt;font style=&quot;font-size: 18px;&quot;&gt;Projects&lt;/font&gt;&lt;/li&gt;&lt;/ul&gt;&lt;font style=&quot;font-size: 18px;&quot;&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; Logical grouping of teams, applications, or business units within the organisation.&lt;br&gt;&lt;br&gt;&lt;/font&gt;&lt;ul&gt;&lt;li&gt;&lt;font style=&quot;font-size: 18px;&quot;&gt;Repos&lt;/font&gt;&lt;/li&gt;&lt;/ul&gt;&lt;font style=&quot;font-size: 18px;&quot;&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; Source code repositories (Git-based).&lt;br&gt;&lt;br&gt;&lt;/font&gt;&lt;ul&gt;&lt;li&gt;&lt;font style=&quot;font-size: 18px;&quot;&gt;Pipelines&lt;/font&gt;&lt;/li&gt;&lt;/ul&gt;&lt;font style=&quot;font-size: 18px;&quot;&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; CI/CD pipelines for automated build, test, and deployment.&lt;br&gt;&lt;br&gt;&lt;/font&gt;&lt;ul&gt;&lt;li&gt;&lt;font style=&quot;font-size: 18px;&quot;&gt;Boards&lt;/font&gt;&lt;/li&gt;&lt;/ul&gt;&lt;font style=&quot;font-size: 18px;&quot;&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; Agile planning tools (Backlogs, Sprints, Kanban boards).&lt;br&gt;&lt;br&gt;&lt;/font&gt;&lt;ul&gt;&lt;li&gt;&lt;font style=&quot;font-size: 18px;&quot;&gt;Artifacts&lt;/font&gt;&lt;/li&gt;&lt;/ul&gt;&lt;font style=&quot;font-size: 18px;&quot;&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp;Package management for NuGet, npm, Maven, etc.&lt;br&gt;&lt;br&gt;&lt;/font&gt;&lt;ul&gt;&lt;li&gt;&lt;font style=&quot;font-size: 18px;&quot;&gt;Test Plans&lt;/font&gt;&lt;/li&gt;&lt;/ul&gt;&lt;font style=&quot;font-size: 18px;&quot;&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; Manual and automated test management.&lt;br&gt;&lt;br&gt;This structure allows enterprises to centralize DevOps processes while maintaining clear separation between teams and workloads.&lt;/font&gt;" vertex="1">
          <mxGeometry height="380" width="777.9" x="232.1" y="1580" as="geometry" />
        </mxCell>
        <mxCell id="1GCHogoU7hfo9mal9Wpi-18" parent="1" style="text;whiteSpace=wrap;html=1;fontSize=18;" value="In modern DevOps especially when using platforms like Microsoft Azure DevOps, security in the pipeline is a shared responsibility..Security is not owned by one team alone. It is embedded across roles,&amp;nbsp;Everyone is Responsible for Pipeline Security." vertex="1">
          <mxGeometry height="50" width="753.66" x="409.68000000000006" y="6610" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
